# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=lab_storage
POSTGRES_USER=lab_user
POSTGRES_PASSWORD=changeme

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_different_strong_random_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── LDAP / Active Directory ──────────────────────────────────────────────────
LDAP_URL=ldap://your-ad-server:389
LDAP_BASE_DN=dc=visteon,dc=com
LDAP_BIND_DN=cn=svc-labstorage,ou=ServiceAccounts,dc=visteon,dc=com
LDAP_BIND_PASSWORD=changeme

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
